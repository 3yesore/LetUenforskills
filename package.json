{
  "name": "letuen",
  "version": "0.2.0-dev",
  "description": "LetUen deconstructs Agent Skills into reports, anchors, Obsidian vaults, and reusable workflow assets.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
    "demo:export": "set PYTHONPATH=src&& python scripts/export_demo.py",
    "demo:serve": "python -m http.server 4173 -d site",
    "demo:check": "node --check site/script.js",
    "bridge": "python scripts/local_bridge.py",
    "local": "python scripts/local_bridge.py"
  },
  "keywords": ["agent-skills", "llm", "obsidian", "workflow", "research"],
  "author": "3yesore",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
