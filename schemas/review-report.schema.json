{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review Report",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "scores",
    "approved_for_publish"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "skill_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "publishable",
        "needs_revision",
        "blocked"
      ]
    },
    "scores": {
      "type": "object",
      "properties": {
        "evidence_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "structure_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "workflow_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "pattern_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "bilingual_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "obsidian_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        }
      }
    },
    "issues": {
      "type": "array"
    },
    "unsupported_claims": {
      "type": "array"
    },
    "missing_evidence": {
      "type": "array"
    },
    "over_inference": {
      "type": "array"
    },
    "approved_for_publish": {
      "type": "object",
      "required": [
        "value",
        "rationale"
      ],
      "properties": {
        "value": {
          "type": "boolean"
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "evidence_audit": {
      "type": "object",
      "properties": {
        "supported_claims": {
          "type": "array"
        },
        "inferred_claims": {
          "type": "array"
        },
        "unsupported_claims": {
          "type": "array"
        },
        "missing_evidence": {
          "type": "array"
        },
        "conflicts": {
          "type": "array"
        },
        "publishable": {
          "type": "string",
          "enum": [
            "publishable",
            "needs_revision",
            "blocked",
            "unknown"
          ]
        },
        "rationale": {
          "type": "string"
        }
      }
    }
  }
}
